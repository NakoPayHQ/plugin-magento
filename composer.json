{
  "name": "nakopay/magento2",
  "description": "NakoPay Bitcoin & crypto payment gateway for Magento 2. Accept BTC, Lightning, LTC, XMR and more.",
  "type": "magento2-module",
  "license": "MIT",
  "version": "1.0.0",
  "homepage": "https://nakopay.com/integrations",
  "support": {
    "issues": "https://github.com/NakoPayHQ/plugin-magento/issues",
    "source": "https://github.com/NakoPayHQ/plugin-magento",
    "docs": "https://nakopay.com/docs/integrations/magento"
  },
  "require": {
    "php": "^8.1",
    "magento/framework": "^103.0",
    "magento/module-payment": "^100.4",
    "magento/module-sales": "^103.0",
    "magento/module-checkout": "^100.4",
    "ext-json": "*",
    "ext-hash": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "files": ["registration.php"],
    "psr-4": {
      "NakoPay\\Magento2\\": ""
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
